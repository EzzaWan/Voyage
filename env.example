# eSIM provider: "esimaccess" (default) or "esimlaunch"
# When esimlaunch: backend calls your esimlaunch API with API key (Easy Way merchant flow).
ESIM_PROVIDER=esimaccess

# eSIM Access (when ESIM_PROVIDER=esimaccess)
ESIM_ACCESS_CODE=
ESIM_SECRET_KEY=
ESIM_API_BASE=https://api.esimaccess.com/api/v1/open

# eSIMLaunch API (when ESIM_PROVIDER=esimlaunch) — use API key from esimlaunch dashboard
ESIMLAUNCH_API_BASE=https://api.esimlaunch.com
ESIMLAUNCH_API_KEY=

# Stripe
STRIPE_SECRET=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# DB (matches docker-compose.yml)
DATABASE_URL=postgresql://postgres:EphtDZiwUHznVRxJTPArvPZtxYmvDoXx@gondola.proxy.rlwy.net:55005/railway

# Redis (for BullMQ queues)
REDIS_URL=redis://localhost:6379

# Upstash Redis (for rate limiting)
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here

# Webhook IP Whitelist (comma-separated, CIDR supported)
# eSIM Access webhook IPs (from docs/esim-access/esim-access-reference.md):
# Stripe doesn't use static IPs - signature verification is sufficient
# Leave empty to disable IP whitelisting (signature verification still applies)
ALLOWED_WEBHOOK_IPS=3.1.131.226,54.254.74.88,18.136.190.97,18.136.60.197,18.136.19.137

# App
WEBHOOK_URL=http://localhost:3000/api/webhooks/esim
APP_URL=http://localhost:3000
WEB_URL=http://localhost:3000

# Admin
ADMIN_EMAILS=youremail@gmail.com,other@gmail.com
NEXT_PUBLIC_ADMIN_EMAILS=youremail@gmail.com,other@gmail.com

# App Store (for "Download on the App Store" badge - get your App ID from App Store Connect)
NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/voyo/idYOUR_APP_ID

# Email Configuration (Resend)
RESEND_API_KEY=
EMAIL_FROM=no-reply@voyoesim.com
MOCK_MODE=false

# Currency Conversion (ExchangeRate-API)
EXCHANGE_RATE_API_KEY=
